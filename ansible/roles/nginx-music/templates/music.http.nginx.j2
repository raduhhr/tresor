# Managed by Ansible: nginx-music (HTTP bootstrap)

map $http_upgrade $connection_upgrade {
  default upgrade;
  ''      close;
}

upstream jellyfin_music_upstream {
  server {{ nginx_music_upstream_host }}:{{ nginx_music_upstream_port }};
  keepalive 32;
}

server {
  listen 80;
  listen [::]:80;
  server_name {{ nginx_music_domain }};

  location /.well-known/acme-challenge/ {
    root /var/www/html;
  }

  # Optional: if backend is not reachable yet, still serve something sane
  location / {
    return 200 "nginx-music bootstrap OK (cert pending)\n";
    add_header Content-Type text/plain;
  }
}
