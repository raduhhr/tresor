# Managed by Ansible: nginx-music (TLS + HARDENED)
# 
# Security improvements:
# - Block Jellyfin API endpoints from public access (except required ones)
# - Add comprehensive security headers
# - Restrict HTTP methods
# - Implement rate limiting
# - Add connection limits

# Rate limiting zones
limit_req_zone $binary_remote_addr zone=jellyfin_general:10m rate=10r/s;
limit_req_zone $binary_remote_addr zone=jellyfin_strict:10m rate=5r/s;
limit_conn_zone $binary_remote_addr zone=jellyfin_conn:10m;

# WebSocket upgrade mapping
map $http_upgrade $connection_upgrade {
  default upgrade;
  ''      close;
}

# Jellyfin upstream
upstream jellyfin_music_upstream {
  server {{ nginx_music_upstream_host }}:{{ nginx_music_upstream_port }};
  keepalive 32;
}

# HTTP -> HTTPS redirect
server {
  listen 80;
  listen [::]:80;
  server_name {{ nginx_music_domain }};

  # ACME challenge path
  location /.well-known/acme-challenge/ {
    root /var/www/html;
  }

  # Everything else redirects to HTTPS
  location / {
    return 301 https://$host$request_uri;
  }
}

# HTTPS server
server {
  listen 443 ssl;
  listen [::]:443 ssl;
  http2 on;

  server_name {{ nginx_music_domain }};

  # SSL certificates
  ssl_certificate     /etc/letsencrypt/live/{{ nginx_music_domain }}/fullchain.pem;
  ssl_certificate_key /etc/letsencrypt/live/{{ nginx_music_domain }}/privkey.pem;

  # SSL configuration (modern, secure)
  ssl_session_timeout 1d;
  ssl_session_cache shared:MozSSL:10m;
  ssl_session_tickets off;
  ssl_protocols TLSv1.2 TLSv1.3;
  ssl_prefer_server_ciphers off;

  # ============================================================
  # SECURITY HEADERS (comprehensive)
  # ============================================================
  {% if nginx_music_hsts %}
  add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;
  {% endif %}
  add_header X-Content-Type-Options "nosniff" always;
  add_header X-Frame-Options "SAMEORIGIN" always;
  add_header X-XSS-Protection "1; mode=block" always;
  add_header Referrer-Policy "no-referrer" always;
  
  # Content Security Policy for Jellyfin
  # Allows inline styles/scripts (required for Jellyfin UI), media from anywhere
  add_header Content-Security-Policy "default-src 'self' 'unsafe-inline' 'unsafe-eval' data: blob:; img-src 'self' data: https:; media-src 'self' blob: https:; connect-src 'self' wss: https:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline' 'unsafe-eval';" always;
  
  # Permissions Policy (restrict dangerous features)
  add_header Permissions-Policy "geolocation=(), microphone=(), camera=(), payment=(), usb=(), magnetometer=(), gyroscope=(), accelerometer=()" always;

  # ============================================================
  # HTTP METHOD RESTRICTIONS
  # ============================================================
  # Only allow GET, POST, HEAD, OPTIONS
  if ($request_method !~ ^(GET|POST|HEAD|OPTIONS)$ ) {
    return 405;
  }

  # ============================================================
  # CONNECTION LIMITS
  # ============================================================
  limit_conn jellyfin_conn 20;

  # ============================================================
  # ALLOW REQUIRED PUBLIC ENDPOINTS (must come BEFORE blocks)
  # ============================================================
  # System/Info/Public is required for Jellyfin web client to connect
  location = /System/Info/Public {
    limit_req zone=jellyfin_general burst=20 nodelay;
    
    proxy_pass http://jellyfin_music_upstream;
    proxy_http_version 1.1;

    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;

    proxy_connect_timeout 60s;
    proxy_read_timeout 3600s;
    proxy_send_timeout 3600s;

    client_max_body_size {{ nginx_music_max_body }};
  }

  # ============================================================
  # BLOCK OTHER JELLYFIN API ENDPOINTS FROM PUBLIC
  # ============================================================
  # Block sensitive System endpoints (but not /System/Info/Public above)
  location ~ ^/System/ {
    access_log /var/log/nginx/jellyfin_blocked.log;
    return 404;
  }

  # Login endpoint (stricter rate limit to prevent brute force)
  # MUST be before the broad Users block below or it gets caught by the 404 return.
  location ~ ^/Users/AuthenticateByName {
    limit_req zone=jellyfin_strict burst=5 nodelay;

    proxy_pass http://jellyfin_music_upstream;
    proxy_http_version 1.1;

    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;

    proxy_connect_timeout 60s;
    proxy_buffering off;
    proxy_request_buffering off;

    client_max_body_size 10M;
  }

  # Block other sensitive endpoints
  location ~ ^/(Users|Branding|health|Sessions|Devices)(/|$) {
    access_log /var/log/nginx/jellyfin_blocked.log;
    return 404;
  }

  # Block common admin/management paths
  location ~ ^/(swagger|api-docs|manage|admin) {
    return 404;
  }

  # ============================================================
  # WEB INTERFACE ONLY (rate limited)
  # ============================================================
  # Allow the web UI and user-facing endpoints
  location /web/ {
    limit_req zone=jellyfin_general burst=20 nodelay;
    
    proxy_pass http://jellyfin_music_upstream;
    proxy_http_version 1.1;

    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_set_header X-Forwarded-Host $host;

    proxy_set_header Upgrade $http_upgrade;
    proxy_set_header Connection $connection_upgrade;

    proxy_read_timeout 3600s;
    proxy_send_timeout 3600s;
    proxy_connect_timeout 60s;

    proxy_buffering off;
    proxy_request_buffering off;

    client_max_body_size {{ nginx_music_max_body }};
  }

  # Authenticated API access (for logged-in users viewing media)
  # This allows the web client to function but blocks unauthenticated enumeration
  location ~ ^/(Items|Audio|Videos|Playback|Images) {
    limit_req zone=jellyfin_general burst=50 nodelay;
    
    # Require authentication header (Jellyfin sets X-Emby-Token for authenticated requests)
    # This prevents direct API enumeration while allowing the web client to work
    if ($http_x_emby_token = "") {
      return 401;
    }
    
    proxy_pass http://jellyfin_music_upstream;
    proxy_http_version 1.1;

    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_set_header X-Forwarded-Host $host;

    proxy_set_header Upgrade $http_upgrade;
    proxy_set_header Connection $connection_upgrade;

    proxy_read_timeout 3600s;
    proxy_send_timeout 3600s;
    proxy_connect_timeout 60s;

    proxy_buffering off;
    proxy_request_buffering off;

    client_max_body_size {{ nginx_music_max_body }};
  }

  # Root redirects to /web
  location = / {
    return 302 /web/;
  }

  # Static assets (CSS, JS, fonts, etc.)
  location ~ ^/(css|fonts|lib|scripts|themes|vendors|plugins) {
    limit_req zone=jellyfin_general burst=100 nodelay;
    
    proxy_pass http://jellyfin_music_upstream;
    proxy_http_version 1.1;

    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;

    # Cache static assets
    proxy_cache_valid 200 7d;
    add_header X-Cache-Status $upstream_cache_status;

    client_max_body_size {{ nginx_music_max_body }};
  }

  # WebSocket for notifications (requires auth)
  location /socket {
    limit_req zone=jellyfin_strict burst=10 nodelay;
    
    if ($http_x_emby_token = "") {
      return 401;
    }
    
    proxy_pass http://jellyfin_music_upstream;
    proxy_http_version 1.1;

    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;

    proxy_set_header Upgrade $http_upgrade;
    proxy_set_header Connection $connection_upgrade;

    proxy_read_timeout 3600s;
    proxy_send_timeout 3600s;
    proxy_connect_timeout 60s;
  }

  # Deny everything else by default
  location / {
    # Log denied attempts for monitoring
    access_log /var/log/nginx/jellyfin_denied.log;
    return 404;
  }
}