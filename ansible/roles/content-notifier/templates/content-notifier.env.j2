# Managed by Ansible - content-notifier
CONTENT_NOTIFIER_WEBHOOK_URL={{ content_notifier_webhook_url | quote }}
CONTENT_NOTIFIER_STATE_FILE={{ content_notifier_state_file | quote }}
CONTENT_NOTIFIER_LOG_FILE={{ content_notifier_log_file | quote }}

CONTENT_NOTIFIER_MIN_AGE_SECONDS={{ content_notifier_min_age_seconds }}
CONTENT_NOTIFIER_REQUEST_TIMEOUT_SECONDS={{ content_notifier_request_timeout_seconds }}
CONTENT_NOTIFIER_MAX_MESSAGE_LEN={{ content_notifier_max_message_len }}
CONTENT_NOTIFIER_DEBUG={{ '1' if content_notifier_debug else '0' }}

CONTENT_NOTIFIER_MESSAGE_PREFIX={{ content_notifier_message_prefix | quote }}
CONTENT_NOTIFIER_IGNORE_HIDDEN={{ '1' if content_notifier_ignore_hidden else '0' }}

# JSON payloads (kept on one line intentionally)
CONTENT_NOTIFIER_PATHS_JSON={{ content_notifier_paths | to_json | quote }}
CONTENT_NOTIFIER_IGNORE_NAMES_JSON={{ content_notifier_ignore_names | to_json | quote }}
CONTENT_NOTIFIER_IGNORE_NAME_CONTAINS_JSON={{ content_notifier_ignore_name_contains | to_json | quote }}