##############################
# File: ./templates/music.tls.nginx.j2
###############################
# Managed by Ansible: nginx-music (TLS)

map $http_upgrade $connection_upgrade {
  default upgrade;
  ''      close;
}

upstream jellyfin_music_upstream {
  server {{ nginx_music_upstream_host }}:{{ nginx_music_upstream_port }};
  keepalive 32;
}

server {
  listen 80;
  listen [::]:80;
  server_name {{ nginx_music_domain }};

  location /.well-known/acme-challenge/ {
    root /var/www/html;
  }

  location / {
    return 301 https://$host$request_uri;
  }
}

server {
  listen 443 ssl;
  listen [::]:443 ssl;
  http2 on;

  server_name {{ nginx_music_domain }};

  ssl_certificate     /etc/letsencrypt/live/{{ nginx_music_domain }}/fullchain.pem;
  ssl_certificate_key /etc/letsencrypt/live/{{ nginx_music_domain }}/privkey.pem;

  {% if nginx_music_hsts %}
  add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;
  {% endif %}
  add_header X-Content-Type-Options nosniff always;
  add_header Referrer-Policy no-referrer always;

  location / {
    proxy_pass http://jellyfin_music_upstream;
    proxy_http_version 1.1;

    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;

    proxy_set_header Upgrade $http_upgrade;
    proxy_set_header Connection $connection_upgrade;

    proxy_read_timeout 3600s;
    proxy_send_timeout 3600s;
    proxy_connect_timeout 10s;

    proxy_buffering off;
    proxy_request_buffering off;

    client_max_body_size {{ nginx_music_max_body }};
  }
}